# =========================
# Telegram
# =========================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
OWNER_ID=

# =========================
# Toobit Futures API
# Never commit real keys
# =========================
TOOBIT_API_KEY=
TOOBIT_SECRET_KEY=
TOOBIT_BASE_URL=https://api.toobit.com
TOOBIT_VERIFY_AFTER_ERROR_SECONDS=70
TOOBIT_TIMEOUT_SECONDS=12
TOOBIT_RECV_WINDOW=5000
TOOBIT_PLACE_REAL_TP=true

# Toobit close confirmation.
# اگر حساب/API تو برای خروج endpoint کانفیرم جدا می‌خواهد، مسیرش را اینجا بگذار.
TOOBIT_CLOSE_CONFIRM_REQUIRED=true
TOOBIT_CLOSE_CONFIRM_DELAY_SECONDS=3
TOOBIT_CLOSE_CONFIRM_RETRY=2
TOOBIT_PATH_CLOSE_CONFIRM=

# =========================
# OKX Public Data
# Used only for analysis/data, not execution
# =========================
OKX_BASE_URL=https://www.okx.com
OKX_TIMEOUT_SECONDS=12

# =========================
# Forex Bot Defaults
# Actual market: Toobit Crypto Futures
# =========================
DEFAULT_TRADE_ENABLED=false
DEFAULT_MARGIN_USDT=10
DEFAULT_LEVERAGE=5
DEFAULT_MAX_POSITIONS=3

# =========================
# Strategy
# =========================
MIN_SYMBOLS_COUNT=50
SIGNAL_THRESHOLD=80
MIN_DAILY_TP_ROOM_PCT=3.0
RISK_REWARD=2.0
FULL_SCAN_SECONDS=30
MONITOR_INTERVAL_SECONDS=2

# =========================
# Smart Exit
# =========================
SMART_EXIT_ENABLED=true
SMART_EXIT_MIN_PROFIT_PCT=0.8
SMART_EXIT_DEFENSE_MAX_LOSS_PCT=0.4
SMART_EXIT_CONFIRMATIONS_REQUIRED=3

# =========================
# Runtime
# =========================
BOT_DATA_DIR=data
TZ=UTC
LOG_LEVEL=INFO
