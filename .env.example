# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Toobit Futures API — never commit real values
TOOBIT_API_KEY=
TOOBIT_API_SECRET=
TOOBIT_BASE_URL=https://api.toobit.com
TOOBIT_RECV_WINDOW=5000

# Public market data
OKX_BASE_URL=https://www.okx.com
BYBIT_BASE_URL=https://api.bybit.com

# Optional paths
RUNTIME_DB_PATH=/root/forex-signal-bot/runtime.db
LEARNING_DB_PATH=/root/forex-signal-bot/learning.db
BACKUP_DIR=/root/forex-signal-bot/backups

# Timing / network
REQUEST_TIMEOUT=10
HTTP_RETRIES=2
HTTP_BACKOFF_SECONDS=0.6
SCAN_INTERVAL_SECONDS=60
# Reuse fresh same-source candles and only fetch a short 1m tail on later scans.
ANALYSIS_CANDLE_CACHE_FRESH_SECONDS=20
VIRTUAL_MONITOR_SECONDS=10
VALIDATOR_INTERVAL_SECONDS=300
BACKUP_INTERVAL_SECONDS=21600
TOOBIT_SNAPSHOT_MAX_AGE_SECONDS=180
# One stale active profile is refreshed per step; learned Stage/Champion is preserved.
PROFILE_REFRESH_STEP_SECONDS=617

# Initial panel defaults (the Telegram commands persist later changes in runtime.db)
DEFAULT_TRADE_MARGIN_USDT=5
DEFAULT_LEVERAGE=10
DEFAULT_MAX_OPEN_POSITIONS=3

# Conservative cost assumptions until real execution history recalibrates them
TOOBIT_TAKER_FEE_RATE=0.0005
DEFAULT_SLIPPAGE_RATE_ROUND_TRIP=0.0004
DEFAULT_FUNDING_RESERVE_RATE=0.0001

# Optional external JSON news calendar. Empty means the feed is disabled.
NEWS_CALENDAR_URL=
